# docextract — environment template.
# Copy to `.env` and fill in only what you use:  cp .env.example .env
# `.env` is gitignored; never commit real keys or private endpoints.
#
# Nothing here is required to run the offline path (EchoLLM / `--offline`);
# each variable is only needed by the backend that reads it.

# --- Provider selection (CLI uses --provider; the MCP server reads these) ---
# One of: anthropic | openai | google | ollama | openai-compat
DOCEXTRACT_PROVIDER=anthropic
# Optional: pin a model; omit to use the chosen provider's default.
# (Required for openai-compat — there's no default model.)
DOCEXTRACT_MODEL=

# --- Cloud provider API keys (set only the ones you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Google accepts either name:
GEMINI_API_KEY=
GOOGLE_API_KEY=

# --- OpenAI-compatible servers (Azure, vLLM, LM Studio, OpenRouter, …) ---
# Point at the server's OpenAI-compatible /v1 endpoint (include the port!).
OPENAI_BASE_URL=http://localhost:8000/v1
# Convenience var used in the live-check example commands; pass it via --model
# or DOCEXTRACT_MODEL (the code itself does not read SERVED_MODEL).
SERVED_MODEL=

# --- Ollama (local, keyless) ---
# Defaults to http://localhost:11434 if unset.
OLLAMA_HOST=

# --- MCP server ---
# Optional path to a YAML registry; defaults to the built-in map.
REGISTRY_PATH=examples/specs.yaml
